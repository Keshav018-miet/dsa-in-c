#include<stdio.h>
#include<stdlib.h>

#define max 100

int tree[max], idx = 0;

void initTree() {
    for(int i = 0; i < max; i++) {
        tree[i] = -1;
    }
}

void insert(int val) {
    if(idx < max) {
        tree[idx++] = val;
    } else {
        printf("TREE IS FULL\n");
    }
}


int search(int val) {
    for(int i = 0; i < idx; i++) {
        if(tree[i] == val)
            return i;   
    }
    return -1;          
}

void deleteNode(int val) {
    int index = search(val);

    if(index == -1) {
        printf("Element not found!\n");
        return;
    }

    
    tree[index] = tree[idx - 1];
    tree[idx - 1] = -1;
    idx--;

    printf("Element deleted successfully!\n");
}


void levelorder() {
    for(int i = 0; i < idx; i++) {
        if(tree[i] != -1)
            printf("%d ", tree[i]);
    }
    printf("\n");
}

void preorder(int index) {
    if(index >= idx || tree[index] == -1)
        return;

    printf("%d ", tree[index]);
    preorder(2 * index + 1);
    preorder(2 * index + 2);
}


void inorder(int index) {
    if(index >= idx || tree[index] == -1)
        return;

    inorder(2 * index + 1);
    printf("%d ", tree[index]);
    inorder(2 * index + 2);
}


void postorder(int index) {
    if(index >= idx || tree[index] == -1)
        return;

    postorder(2 * index + 1);
    postorder(2 * index + 2);
    printf("%d ", tree[index]);
}

int main() {
    int choice, val;
    initTree();

    while(1) {
        printf("\n ***** Binary Tree Menu *****\n");
        printf("1. Insert\n");
        printf("2. Delete\n");
        printf("3. Level Order Traversal\n");
        printf("4. Pre-Order Traversal\n");
        printf("5. In-Order Traversal\n");
        printf("6. Post-Order Traversal\n");
        printf("7. Search\n");
        printf("8. Exit\n");
        printf("Enter Choice: ");
        scanf("%d", &choice);

        switch(choice) {
            case 1:
                printf("Enter Value: ");
                scanf("%d", &val);
                insert(val);
                break;

            case 2:
                printf("Enter Deleting Element: ");
                scanf("%d", &val);
                deleteNode(val);
                break;

            case 3:
                levelorder();
                break;

            case 4:
                preorder(0);
                printf("\n");
                break;

            case 5:
                inorder(0);
                printf("\n");
                break;

            case 6:
                postorder(0);
                printf("\n");
                break;

            case 7:
                printf("Enter Searching Element: ");
                scanf("%d", &val);
                if(search(val) == -1)
                    printf("Not Found !!\n");
                else
                    printf("Found !!\n");
                break;

            case 8:
                exit(0);

            default:
                printf("Invalid choice !!!!\n");
        }
    }
    return 0;
}
