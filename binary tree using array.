#include<stdio.h>
#include<stdlib.h>
#define max 100
int tree[max], idx=0;
void initTree(){
    for(int i=0; i<max; i++){
        tree[i] = -1;
    }
}

void insert(int val){
    if(idx<max){
        tree[idx++] = val;
    }
    else
        printf("TREE IS FULL\n");
}
void delete(int val){
    for(int i=0; i<idx; i++){
        if(tree[i] == val){
            tree[i] = -1;
            return;
        }
    }
    printf("Value not found in tree.\n");
}
int search(int val){
    for(int i=0; i<idx; i++){
        if(tree[i] == val)
            return 1;
    }
    return 0;
}

void levelorder(){
    for(int i=0; i<idx; i++){
        if(tree[i] != -1)
            printf("%d ",tree[i]);
    }
}

void preorder(int index){
    if(index>=max || tree[index] == -1)
        return;
    printf("%d ", tree[index]);
    preorder(2*index+1);
    preorder(2*index+2);
}

void inorder(int index){
    if(index>=max || tree[index] == -1)
        return;
    printf("%d ", tree[index]);
    preorder(2*index+1);
    preorder(2*index+2);
}


void postorder(int index){
    if(index>=max || tree[index] == -1)
        return;
    printf("%d ", tree[index]);
    preorder(2*index+1);
    preorder(2*index+2);
}



int main(){
    int choice, val;
    initTree();
    while (1){
        printf("\n ***** Binary Tree Menu *****\n");
        printf("1. Insert\n");
        printf("2. Delete\n");
        printf("3. Level Order Traversal\n");
        printf("4. Pre-Order Traversal\n");
        printf("5. In-Order Traversal\n");
        printf("6. Post-Order Traversal\n");
        printf("7. Search\n");
        printf("8. Display Tree\n");
        printf("9. Exit\n");
        printf("Enter Choice: ");
        scanf("%d", &choice);
        switch(choice){
            case 1:
                printf("Enter value to insert: ");
                scanf("%d", &val);
                insert(val);
                break;
            case 2:
            printf("Enter value to delete: ");
                scanf("%d", &val);
                delete(val);
                 
                break;
            case 3:
                levelorder();   
                break;
            case 4:
                preorder(0);
                break;
            case 5:
                inorder(0);

                break;
            case 6:
                postorder(0);
                break;
            case 7:
            printf("Enter search value: ");
                scanf("%d", &val);
                if(search(val))
                    printf("Value found.\n");
                else
                    printf("Value not found.\n");
                break;
             case 8:
                    levelorder();
                break;
            case 9:
                exit(0);
            default:
                printf("Invalid choice !!!!\n");
        }
    }
    
}
