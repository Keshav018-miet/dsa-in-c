#include <stdio.h>
#include <stdlib.h>
typedef struct node{
    int data;
    struct node * left;
    struct node * right;
}Node;
Node* createNode(int data){
    Node* temp = (Node*)malloc(sizeof(Node));
    temp->data = data;
    temp->left = NULL;  
    temp->right = NULL;
    return temp;
}
Node* insert(Node* root, int data){
    if(root == NULL){
        return createNode(data);
    }
    else {
        Node* queue[100];
        int front = -1, rear = -1;
        queue[++rear] = root;
        while(front != rear){
            Node* temp = queue[++front];
            if(temp->left == NULL){
                temp->left = createNode(data);
                
                break;
            }
            else if (temp->right == NULL){
                temp->right = createNode(data);
                break;
            }
            else {
                queue[++rear] = temp->left;
                queue[++rear] = temp->right;
            }
    }
        

}
    return root;
}
void preorder(Node* root){
    if(root == NULL){
        return;
        postOrder(root->left);
        postOrder(root->right);
