}
}
void inorder(Node* root){
    if(root == NULL){
        return;
         preOrder(root->data);
        preOrder(root->left);
        preOrder(root->right);
    }
}
void postorder(Node* root){
    if(root == NULL){
        return;
        postOrder(root->left);
        postOrder(root->right);
        printf("%d ", root->data);
    }
}
Node* search(Node* root, int data){
  if(root == NULL)
    return NULL;
  Node* queue[100];
  int front = -1, rear = -1;
    queue[++rear] = root;
    front++;
    while(front<=rear){
        Node* temp = queue[front++];
        if(temp->data == data){
            return temp;
        }
        if(temp->left != NULL){
            queue[++rear] = temp->left;
        }
        if(temp->right != NULL){
            queue[++rear] = temp->right;
        }
        return NULL;
    }
}
void* delete(Node* root, int data){
    if(root == NULL){
        return NULL;
    }
    Node* queue[100];
    int front = -1, rear = -1;
    queue[++rear] = root;
    while(front != rear){
        Node* temp = queue[++front];
        if(temp->data == data){
            temp->data = queue[rear]->data;
            free(queue[rear]);
            rear--;
            break;
        }
        if(temp->left != NULL){
            queue[++rear] = temp->left;
        }
        if(temp->right != NULL){
            queue[++rear] = temp->right;
        }
    }
    
}

